View(id="main_view", title="CoreUI Test Dashboard") {
    Stack(id="header_stack", dir="v", gap=15px) {
        Text(id="welcome_text", value="System Initialized", size=24px, weight="bold")
        Box(id="status_indicator", background="#00ff00", padding=10px) {
            Text(id="status_label", value="All Systems Nominal")
        }
    }
    Grid(id="action_grid", cols=["1*", "1*"], gap=20px) {
        Trigger(id="btn_logs", label="View Logs", action="sys:fetch_logs(limit=50, level='debug')")
        Trigger(id="btn_settings", label="Settings", action="ui:navigate(target='settings_page')")
    }
}
